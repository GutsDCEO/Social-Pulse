# ===========================================
# social-pulse — Environment Variables
# ===========================================
# Copy this file to .env and fill in values:
# cp .env.example .env
# ===========================================

# --- General ---
APP_ENV=development
APP_PORT=8080

# --- Database ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=socialpulse_db
DB_USER=postgres
DB_PASSWORD=changeme

# --- JWT ---
JWT_SECRET=CHANGE_THIS_TO_A_SECURE_RANDOM_STRING
JWT_ACCESS_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=604800000

# --- Docker ---
COMPOSE_PROJECT_NAME=social-pulse

# --- pgAdmin ---
PGADMIN_EMAIL=admin@socialpulse.com
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050
