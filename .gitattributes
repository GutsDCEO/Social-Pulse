# Handle line endings automatically for files detected as text
# and perform LF normalization
* text=auto

# Declare files that will always have CRLF line endings on checkout.
*.cmd text eol=crlf
*.bat text eol=crlf

# Denote all files that are truly binary and should not be modified.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mov binary
*.mp4 binary
*.wmv binary
*.flv binary
*.avi binary
*.swf binary

# Explicitly set eol for sensitive files
/mvnw text eol=lf
/social-pulse/mvnw text eol=lf
